# Vercel Configuration for ClubPesca

# Frontend (React + Vite)
[build]
  command = "cd frontend && npm install && npm run build"
  publish = "frontend/dist"

# Backend (Node.js)
[backend]
  command = "cd backend && npm install"
  # Para deploy de API, configure via Vercel serverless ou edge functions se necessário

# Ignorar arquivos desnecessários
[ignore]
  files = ["**/node_modules", "**/.env.local"]
